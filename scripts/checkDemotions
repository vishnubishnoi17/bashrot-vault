#!/bin/bash
# =============================================================================
# checkDemotions — Restore bashers from rbash after 30-minute penalty expires
# Run by root cron every minute: * * * * * /scripts/checkDemotions
# =============================================================================
RBASH_DURATION=1800   # 30 minutes in seconds
AUDIT_LOG="/var/log/vault/penalty_audit.log"

mkdir -p /var/run/vault "$(dirname "$AUDIT_LOG")"

for demotion_file in /var/run/vault/demoted_*; do
    [[ -f "$demotion_file" ]] || continue
    username="${demotion_file##*/demoted_}"
    demoted_at=$(cat "$demotion_file" 2>/dev/null) || continue
    now=$(date +%s)

    if (( now - demoted_at >= RBASH_DURATION )); then
        # Restore shell to bash
        usermod -s /bin/bash "$username" 2>/dev/null || true

        # Remove the restricted PATH line injected during demotion
        bashrc="/home/bashers/${username}/.bashrc"
        [[ -f "$bashrc" ]] && \
            sed -i '/^export PATH=.*restricted_bin/d' "$bashrc" 2>/dev/null || true

        # Clean up restricted_bin dir
        rm -rf "/home/bashers/${username}/.restricted_bin" 2>/dev/null || true

        rm -f "$demotion_file"
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] RESTORED: $username (demotion expired)" \
            >> "$AUDIT_LOG"
        wall "✅ Basher '${username}' demotion period over — shell restored." 2>/dev/null || true
    fi
done
